# Vercel Deployment Environment Variables
# Add these in your Vercel Dashboard -> Settings -> Environment Variables

# HuggingFace Token (with WRITE access to your dataset repo)
# Required for telemetry to work
HF_TOKEN=hf_...

# The target HuggingFace dataset repository for telemetry
# Format: username/repo
HF_DATASET_REPO=your-username/your-dataset

# Optional: The branch to commit to (defaults to main)
# HF_DATASET_BRANCH=main
